# Auto-detect text files and normalize line endings to LF in repo
* text=auto eol=lf

# Force shell scripts to LF
*.sh text eol=lf
/mvnw text eol=lf

# Force Windows scripts to CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
